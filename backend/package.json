{
  "name": "donghua3d-backend",
  "version": "1.0.0",
  "description": "Enterprise-grade Express API server for Donghua3D",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts",
    "update-studios": "ts-node src/scripts/update_studios.ts",
    "auto-update": "ts-node src/scripts/auto_update_episodes.ts",
    "purge-unwanted": "ts-node src/scripts/purge_live_action_and_fix_slugs.ts",
    "backfill-airing-days": "ts-node src/scripts/backfill_airing_days.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "express",
    "prisma",
    "typescript",
    "hls",
    "transcoding"
  ],
  "author": "iamnguyenvu",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@prisma/client": "^5.12.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fluent-ffmpeg": "^2.1.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.12.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
