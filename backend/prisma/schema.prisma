datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Custom Enums (matching 02_data_spec.md & Phase 2 Upgrades)
enum Role {
  USER
  EXPERT
  ADMIN
}

enum Tier {
  S
  A
  B
  C
  D
  F
}

enum RatingType {
  USER
  EXPERT
}

enum AudioTrack {
  VIETSUB
  THUYET_MINH
  DUAL_AUDIO
}

enum ScrapingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// 1. User Entity Model
model User {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String             @unique @db.VarChar(255)
  password        String             @db.VarChar(255)
  role            Role               @default(USER)
  reputationScore Int                @default(100)
  veteranSince    DateTime?          @db.Timestamptz
  level           Int                @default(1)
  exp             Int                @default(0)
  donghuaCoins    Int                @default(0)
  cultivationRank String             @default("Luyện Khí Kỳ")
  createdAt       DateTime           @default(now()) @db.Timestamptz
  ratings         Rating[]
  comments        Comment[]
  danmakus        Danmaku[]
  watchHistories  WatchHistory[]
  personalTiers   PersonalTierList[]
  watchlist       Watchlist[]
  behaviorLogs    UserBehaviorLog[]
}

// 2. Movie Entity Model
model Movie {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String     @db.VarChar(255)
  slug           String     @unique @default(dbgenerated("gen_random_uuid()")) @db.VarChar(255)
  altTitles      Json       @default("[]") // JSONB format
  description    String?    @db.Text
  bannerUrl      String?    @db.VarChar(512)
  posterUrl      String?    @db.VarChar(512)
  studio         String?    @db.VarChar(255)
  releaseYear    Int
  viewsCount     Int        @default(0) // Popularity views counter
  airingDay      Int? // Optional day of week (1=Mon, ..., 7=Sun)
  seriesId       String?    @db.Uuid
  seriesLabel    String?    @db.VarChar(255) // Quick series label (e.g. "Season 2", "Movie")
  rating         Float      @default(0.0)
  expertRating   Float      @default(0.0)
  audienceRating Float      @default(0.0)
  imdbRating     Float?
  audioTrack     AudioTrack @default(VIETSUB)
  loreMetadata   Json?
  status         String     @default("ongoing") @db.VarChar(20) // "ongoing", "completed", "upcoming"
  totalEpisodes  Int?       // Tổng số tập dự kiến (ví dụ 180)
  createdAt      DateTime   @default(now()) @db.Timestamptz
  updatedAt      DateTime   @updatedAt @db.Timestamptz

  // Relations
  series        MovieSeries?           @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  episodes      Episode[]
  ratings       Rating[]
  comments      Comment[]
  danmakus      Danmaku[]
  personalTiers PersonalTierList[]
  leaderboard   GlobalTierLeaderboard?
  watchlist     Watchlist[]
  genres        MovieGenre[]

  @@index([releaseYear(sort: Desc), rating(sort: Desc)], name: "idx_movie_release_rating")
  @@index([viewsCount(sort: Desc)], name: "idx_movie_popularity")
  @@index([audioTrack], name: "idx_movie_audio_track")
  @@index([status], name: "idx_movie_status")
}

// 2b. MovieSeries Entity Model
model MovieSeries {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255) // E.g. "Đấu Phá Thương Khung Universe"
  createdAt DateTime @default(now()) @db.Timestamptz
  movies    Movie[]
}

// 3. Episode Entity Model
model Episode {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  movieId        String          @db.Uuid
  episodeNumber  Int
  title          String          @db.VarChar(255)
  description    String?         @db.Text
  videoUrl       String          @db.VarChar(512) // Local index.m3u8 path or CloudFront S3 path
  videoUrl4k     String?         @db.VarChar(512) // Optional Cloudflare R2 4K VIP stream
  duration       Float           @default(0.0) // In seconds
  introStart     Float           @default(0.0) // Video second offset where OP song starts
  introEnd       Float           @default(0.0) // Video second offset where OP song ends
  outroStart     Float           @default(0.0) // Video second offset where ED song starts
  outroEnd       Float           @default(0.0) // Video second offset where ED song ends
  thumbnail      String?         @db.VarChar(512) // Video thumbnail screen grab
  audioTrack     AudioTrack      @default(VIETSUB)
  rating         Float           @default(0.0)
  expertRating   Float           @default(0.0)
  audienceRating Float           @default(0.0)
  createdAt      DateTime        @default(now()) @db.Timestamptz
  updatedAt      DateTime        @updatedAt @db.Timestamptz
  movie          Movie           @relation(fields: [movieId], references: [id], onDelete: Cascade)
  ratings        Rating[]
  comments       Comment[]
  danmakus       Danmaku[]
  watchHistories WatchHistory[]
  sources        EpisodeSource[]

  @@unique([movieId, episodeNumber], name: "unique_movie_episode")
  @@index([movieId, episodeNumber(sort: Asc)], name: "idx_episode_movie_number")
  @@index([audioTrack], name: "idx_episode_audio_track")
}

// 3b. EpisodeSource Model
model EpisodeSource {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  episodeId  String   @db.Uuid
  serverName String   @db.VarChar(50)
  videoUrl   String   @db.VarChar(512)
  priority   Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz
  episode    Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId, priority(sort: Desc)], name: "idx_episode_source_priority")
}

// 4. Rating Entity Model
model Rating {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String     @db.Uuid
  movieId    String     @db.Uuid
  episodeId  String?    @db.Uuid // Optional, only present when rating a specific episode
  ratingType RatingType @default(USER)
  value      Int // 1 - 10
  review     String?    @db.Text
  isCredible Boolean    @default(true)
  isApproved Boolean    @default(true)
  createdAt  DateTime   @default(now()) @db.Timestamptz
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie      Movie      @relation(fields: [movieId], references: [id], onDelete: Cascade)
  episode    Episode?   @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([movieId, isCredible, isApproved], name: "idx_rating_verification")
}

// 5. Nested Comment Model (Recursive threading support)
model Comment {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  movieId   String    @db.Uuid
  episodeId String?   @db.Uuid // Optional, can comment on whole movie or specific episode
  parentId  String?   @db.Uuid // Self-reference for recursive threading
  content   String    @db.Text
  isSpoiler Boolean   @default(false)
  isFlagged Boolean   @default(false)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  episode   Episode?  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  @@index([movieId, episodeId, parentId, createdAt(sort: Desc)], name: "idx_comment_traversal")
}

// 6. Watch History Model
model WatchHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  episodeId String   @db.Uuid
  progress  Float    @default(0.0) // Playback time in seconds
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt @db.Timestamptz
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId], name: "unique_user_watch_progress")
}

// 6b. User Behavior Tracking Log Model (Analytics)
model UserBehaviorLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @db.Uuid
  action    String   @db.VarChar(50) // e.g. 'PAGE_VIEW', 'VIDEO_PLAY', 'SEARCH'
  metadata  Json?    // Stores path, query, videoTime, etc.
  createdAt DateTime @default(now()) @db.Timestamptz

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt(sort: Desc)], name: "idx_behavior_action_time")
  @@index([userId], name: "idx_behavior_user")
}


// 7. Personal Tier List Model
model PersonalTierList {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  movieId   String   @db.Uuid
  tier      Tier
  notes     String?  @db.Text
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId], name: "unique_user_movie_tier")
  @@index([userId, tier], name: "idx_tierlist_user")
}

// 8. Global Tier Leaderboard Cache Model
model GlobalTierLeaderboard {
  movieId        String   @id @db.Uuid
  s_tier_count   Int      @default(0)
  a_tier_count   Int      @default(0)
  b_tier_count   Int      @default(0)
  c_tier_count   Int      @default(0)
  d_tier_count   Int      @default(0)
  f_tier_count   Int      @default(0)
  tierScore      Float    @default(0.0) // Cumulative weighted rank variable
  globalTier     Tier     @default(C)
  rank           Int?
  lastCalculated DateTime @default(now()) @db.Timestamptz
  movie          Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

// 9. Watchlist (Favorites) Model
model Watchlist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  movieId   String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId], name: "unique_user_movie_watchlist")
  @@index([userId], name: "idx_watchlist_user")
}

// 10. ScrapingLog Model
model ScrapingLog {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startedAt   DateTime  @default(now()) @db.Timestamptz
  completedAt DateTime? @db.Timestamptz
  status      String    @db.VarChar(50) // 'PENDING', 'SUCCESS', 'FAILED'
  syncedCount Int       @default(0)
  results     Json      @default("[]") // JSON list of detailed messages
  error       String?   @db.Text
}

// 11. ScrapingQueue Staging Model (Hybrid Pipeline Phase 2)
model ScrapingQueue {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceUrl  String         @db.VarChar(1024)
  title      String         @db.VarChar(255)
  episodeNum Int
  audioTrack AudioTrack     @default(VIETSUB)
  status     ScrapingStatus @default(PENDING)
  attempts   Int            @default(0)
  errorLog   String?        @db.Text
  createdAt  DateTime       @default(now()) @db.Timestamptz
  updatedAt  DateTime       @updatedAt @db.Timestamptz

  @@index([status, createdAt], name: "idx_scraping_queue_status")
}

// 12. Genre Model
model Genre {
  id     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name   String       @unique @db.VarChar(100)
  slug   String       @unique @db.VarChar(100)
  movies MovieGenre[]
}

// 13. MovieGenre Link Model
model MovieGenre {
  movieId String @db.Uuid
  genreId String @db.Uuid
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
  @@index([genreId], name: "idx_movie_genre")
}

// 14. Danmaku Model (Real-time bullet comments)
model Danmaku {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  movieId   String   @db.Uuid
  episodeId String   @db.Uuid
  text      String   @db.Text
  time      Float    // offset in seconds in video player timeline
  color     String   @default("#ffffff") @db.VarChar(50)
  style     String   @default("scroll") @db.VarChar(50) // scroll, top, bottom
  createdAt DateTime @default(now()) @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie   Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId, time])
}

// 15. News Model (Auto-scraped articles & updates)
model News {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  summary     String   @db.Text
  content     String   @db.Text
  imageUrl    String?  @db.VarChar(512)
  sourceUrl   String?  @db.VarChar(512)
  author      String   @default("Donghua3D Admin") @db.VarChar(100)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([createdAt(sort: Desc)], name: "idx_news_created_at")
}
