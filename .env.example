# ==============================================================================
# DONGHUA3D ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# Copy this file to '.env' and adjust values for your environment.
# ==============================================================================

# --- DATABASE CONFIGURATION ---
# local compose uri: postgresql://donghua_db_admin:production_secure_db_password_hash_2026@localhost:5432/donghua_prod_db?schema=public
# docker-internal compose uri: postgresql://donghua_db_admin:production_secure_db_password_hash_2026@db:5432/donghua_prod_db?schema=public&connection_limit=10
DATABASE_URL="postgresql://donghua_db_admin:secure_password_here@localhost:5432/donghua_prod_db?schema=public"

# --- BACKEND SERVER PORT ---
PORT=5000

# --- JWT CRYPTOGRAPHIC SECRET ---
# Run 'openssl rand -base64 32' to generate a secure secret key
JWT_SECRET="generate_a_secure_32_character_key_here"

# --- MEDIA STORAGE CONFIGURATION ---
# Options: LOCAL (for direct EC2 disk storage), S3 (for AWS S3 bucket writes)
STORAGE_PROVIDER="LOCAL"

# --- LOCAL FILE SYSTEM PATH ---
# Path where media directories exist inside the backend container
UPLOAD_DIR="/app/uploads"

# --- AWS S3 CREDENTIALS (Required only when STORAGE_PROVIDER=S3) ---
AWS_ACCESS_KEY_ID="your_aws_access_key_id_here"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key_here"
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET="donghua3d-media-bucket"

# --- CLIENT (FRONTEND) INTERACTION ORIGIN ---
# Restricts CORS requests to specified client domains
CLIENT_URL="http://localhost:3000"
